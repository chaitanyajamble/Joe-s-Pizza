import sys
import argparse
import unittest

from selenium import webdriver
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.common.exceptions import TimeoutException, NoSuchElementException

BASE_URL = "https://www.joespizza.com"
WAIT_TIMEOUT = 15

# Expected nav items -> partial link text and expected URL fragment
NAV_ITEMS = [
    ("MENU", "menu-joes-pizza"),
    ("DELIVERY", "delivery-1-joes-pizza"),
    ("PICK UP", "general-1"),
    ("CATERING", "catering-menu"),
    ("REVIEWS", "awards"),
]

VIEWPORTS = [
    ("desktop", 1920, 1080),
    ("tablet", 768, 1024),
    ("mobile", 375, 812),
]


def make_driver(browser):
    if browser == "chrome":
        options = webdriver.ChromeOptions()
        options.add_argument("--start-maximized")
        options.add_argument("--headless=new")
        return webdriver.Chrome(options=options)

    if browser == "firefox":
        options = webdriver.FirefoxOptions()
        options.add_argument("--width=1920")
        options.add_argument("--height=1080")
        options.add_argument("-headless")
        return webdriver.Firefox(options=options)

    if browser == "edge":
        options = webdriver.EdgeOptions()
        options.add_argument("--start-maximized")
        options.add_argument("--headless=new")
        return webdriver.Edge(options=options)

    raise ValueError(f"Unsupported browser: {browser}")


def load_home(driver):
    driver.get(BASE_URL)
    WebDriverWait(driver, WAIT_TIMEOUT).until(
        EC.presence_of_element_located((By.TAG_NAME, "body"))
    )


class JoesPizzaTestCase(unittest.TestCase):
    """
    Base test case. BROWSER is set dynamically per subclass by
    build_suite_for_browser() below, so the same test bodies run
    once per browser.
    """

    BROWSER = "chrome" # overridden per subclass

    def setUp(self):
        self.driver = make_driver(self.BROWSER)
        self.driver.implicitly_wait(5)

    def tearDown(self):
        self.driver.quit()

    # ---------------- Page load ----------------

    def test_homepage_loads_with_correct_title(self):
        load_home(self.driver)
        WebDriverWait(self.driver, WAIT_TIMEOUT).until(
            EC.title_contains("Joe's Pizza")
        )
        self.assertIn("Joe's Pizza", self.driver.title)

    def test_homepage_status_no_error_banner(self):
        load_home(self.driver)
        body_text = self.driver.find_element(By.TAG_NAME, "body").text.lower()
        for phrase in ("404", "page not found", "site is temporarily unavailable"):
            self.assertNotIn(phrase, body_text)

    def test_page_source_not_empty(self):
        load_home(self.driver)
        self.assertGreater(len(self.driver.page_source), 500)

    # ---------------- Navigation ----------------

    def test_nav_links_present_and_navigate(self):
        for link_text, url_fragment in NAV_ITEMS:
            with self.subTest(link=link_text):
                load_home(self.driver)
                try:
                    link = WebDriverWait(self.driver, WAIT_TIMEOUT).until(
                        EC.element_to_be_clickable((By.PARTIAL_LINK_TEXT, link_text))
                    )
                except TimeoutException:
                    self.fail(f"Nav link '{link_text}' not found or not clickable")

                link.click()

                WebDriverWait(self.driver, WAIT_TIMEOUT).until(
                    lambda d: url_fragment in d.current_url
                    or len(d.window_handles) > 1
                )

                if len(self.driver.window_handles) > 1:
                    self.driver.switch_to.window(self.driver.window_handles[-1])

                self.assertIn(
                    url_fragment,
                    self.driver.current_url,
                    f"Expected '{url_fragment}' in URL after clicking '{link_text}', "
                    f"got {self.driver.current_url}",
                )

    def test_logo_links_back_to_home(self):
        load_home(self.driver)
        menu_link = WebDriverWait(self.driver, WAIT_TIMEOUT).until(
            EC.element_to_be_clickable((By.PARTIAL_LINK_TEXT, "MENU"))
        )
        menu_link.click()
        WebDriverWait(self.driver, WAIT_TIMEOUT).until(
            lambda d: "menu-joes-pizza" in d.current_url
        )

        home_link = WebDriverWait(self.driver, WAIT_TIMEOUT).until(
            EC.element_to_be_clickable((By.PARTIAL_LINK_TEXT, "HOME"))
        )
        home_link.click()
        WebDriverWait(self.driver, WAIT_TIMEOUT).until(
            lambda d: d.current_url.rstrip("/") == BASE_URL
        )
        self.assertEqual(self.driver.current_url.rstrip("/"), BASE_URL)

    # ---------------- Contact / ordering ----------------

    def test_phone_order_link_present(self):
        load_home(self.driver)
        try:
            phone_link = self.driver.find_element(By.CSS_SELECTOR, "a[href^='tel:']")
        except NoSuchElementException:
            self.fail("No tel: phone link found on homepage")
        self.assertTrue(phone_link.get_attribute("href").startswith("tel:"))

    def test_social_links_present(self):
        load_home(self.driver)
        socials = self.driver.find_elements(
            By.CSS_SELECTOR,
            "a[href*='facebook.com'], a[href*='instagram.com'], a[href*='x.com']",
        )
        self.assertGreater(len(socials), 0, "No social media links found on homepage")

    def test_order_button_present(self):
        load_home(self.driver)
        order_elements = self.driver.find_elements(By.PARTIAL_LINK_TEXT, "Order")
        self.assertGreater(len(order_elements), 0, "No 'Order' call-to-action found")

    # ---------------- Responsive / compatibility ----------------

    def test_page_renders_at_all_viewports(self):
        for name, width, height in VIEWPORTS:
            with self.subTest(viewport=name):
                self.driver.set_window_size(width, height)
                load_home(self.driver)
                body = self.driver.find_element(By.TAG_NAME, "body")
                self.assertTrue(
                    body.is_displayed(),
                    f"Body not displayed at {name} viewport ({width}x{height})",
                )

    def test_no_horizontal_overflow_on_mobile(self):
        self.driver.set_window_size(375, 812)
        load_home(self.driver)
        scroll_width = self.driver.execute_script(
            "return document.documentElement.scrollWidth"
        )
        client_width = self.driver.execute_script(
            "return document.documentElement.clientWidth"
        )
        # Allow a small tolerance for scrollbar rendering differences
        self.assertLessEqual(
            scroll_width,
            client_width + 20,
            f"Horizontal overflow detected: scrollWidth={scroll_width}, "
            f"clientWidth={client_width}",
        )


def build_suite_for_browsers(browsers):
    """Create one TestCase subclass per browser so results are reported
    separately (e.g. JoesPizzaTestCase_chrome, JoesPizzaTestCase_firefox)."""
    suite = unittest.TestSuite()
    loader = unittest.TestLoader()

    for browser in browsers:
        cls_name = f"JoesPizzaTestCase_{browser}"
        browser_cls = type(cls_name, (JoesPizzaTestCase,), {"BROWSER": browser})
        suite.addTests(loader.loadTestsFromTestCase(browser_cls))

    return suite


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Run joespizza.com Selenium tests")
    parser.add_argument(
        "--browser",
        choices=["chrome", "firefox", "edge"],
        help="Run against a single browser only (default: run all three)",
    )
    args, remaining = parser.parse_known_args()

    browsers_to_run = [args.browser] if args.browser else ["chrome", "firefox", "edge"]

    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(build_suite_for_browsers(browsers_to_run))

    sys.exit(0 if result.wasSuccessful() else 1)
