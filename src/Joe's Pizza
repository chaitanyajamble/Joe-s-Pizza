@app.post("/cart/{cart_id}/items", response_model=CartOut, tags=["Cart"])
def add_to_cart(
    cart_id: int,
    item: CartItemCreate,
    current: Customer = Depends(get_current_customer),
    db: Session = Depends(get_db),
):
    """Add a menu item to the cart."""
    cart = db.query(Cart).filter(Cart.id == cart_id, Cart.customer_id == current.id).first()
    if not cart:
        raise HTTPException(status_code=404, detail="Cart not found")
    menu_item = db.query(MenuItem).filter(MenuItem.id == item.menu_item_id, MenuItem.is_available == True).first()
    if not menu_item:
        raise HTTPException(status_code=404, detail="Menu item not found or unavailable")

    # Merge if same item already in cart
    existing = next((ci for ci in cart.items if ci.menu_item_id == item.menu_item_id), None)
    if existing:
        existing.quantity += item.quantity
    else:
        db.add(CartItem(
            cart_id=cart.id,
            menu_item_id=item.menu_item_id,
            quantity=item.quantity,
            special_instructions=item.special_instructions,
        ))
    db.commit()
    db.refresh(cart)
    return {**cart.__dict__, "subtotal": cart_subtotal(cart)}


@app.delete("/cart/{cart_id}/items/{cart_item_id}", response_model=CartOut, tags=["Cart"])
def remove_from_cart(
    cart_id: int,
    cart_item_id: int,
    current: Customer = Depends(get_current_customer),
    db: Session = Depends(get_db),
):
    cart = db.query(Cart).filter(Cart.id == cart_id, Cart.customer_id == current.id).first()
    if not cart:
        raise HTTPException(status_code=404, detail="Cart not found")
    ci = db.query(CartItem).filter(CartItem.id == cart_item_id, CartItem.cart_id == cart_id).first()
    if not ci:
        raise HTTPException(status_code=404, detail="Cart item not found")
    db.delete(ci)
    db.commit()
    db.refresh(cart)
    return {**cart.__dict__, "subtotal": cart_subtotal(cart)}



@app.post("/orders", response_model=OrderOut, tags=["Orders"])
def place_order(
    data: OrderCreate,
    current: Customer = Depends(get_current_customer),
    db: Session = Depends(get_db),
):
    """Convert a cart into a confirmed order."""
    cart = db.query(Cart).filter(Cart.id == data.cart_id, Cart.customer_id == current.id).first()
    if not cart or not cart.items:
        raise HTTPException(status_code=400, detail="Cart is empty or not found")
    if data.order_type == "delivery" and not data.delivery_address:
        raise HTTPException(status_code=400, detail="Delivery address required")

    total = cart_subtotal(cart)
    order = Order(
        customer_id=current.id,
        location_id=cart.location_id,
        status="confirmed",
        total=total,
        order_type=data.order_type,
        delivery_address=data.delivery_address,
    )
    db.add(order)
    db.flush()

    for ci in cart.items:
        db.add(OrderItem(
            order_id=order.id,
            menu_item_id=ci.menu_item_id,
            quantity=ci.quantity,
            unit_price=ci.menu_item.price,
            special_instructions=ci.special_instructions,
        ))

    # Clear cart after order
    for ci in cart.items:
        db.delete(ci)
    db.delete(cart)
    db.commit()
    db.refresh(order)
    return order


